FROM python:3.11-slim AS test

WORKDIR /app

RUN apt-get update && apt-get install -y \
    libpq-dev \
    gcc \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml ./
COPY src/ ./src/
COPY tests/ ./tests/

RUN pip install --no-cache-dir -e . \
    && pip install --no-cache-dir ".[test]"

ENV PYTHONPATH=/app \
    DATABASE_URL=postgresql+psycopg://test:test@postgres:5432/test_db

CMD ["pytest", "-v", "--tb=short", "--maxfail=1", "--asyncio-mode=auto"]
